{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "orbi-worker",
	"main": "src/index.ts",
	"compatibility_date": "2026-03-10",
	"observability": { "enabled": true },
	"assets": { "directory": "./public/", "binding": "ASSETS" },
	"routes": [
		{
			"pattern": "orbicowork.arqxus.com/*",
			"custom_domain": false
		}
	]
}
